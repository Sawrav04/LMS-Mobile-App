{
  "expo": {
    "name": "LMS Mobile",
    "slug": "lms-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lms-mobile",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#667eea"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.logistics.lmsmobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera access to scan QR codes on shipments"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#667eea",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.logistics.lmsmobile",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera access to scan QR codes on shipments"
        }
      ]
    ]
  }
}
